{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ggomggombath",
  "compatibility_date": "2026-05-15",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "ggomggombath.com",
      "custom_domain": true
    },
    {
      "pattern": "www.ggomggombath.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist/client"
  }
}
